<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.0" xmlns="https://jakarta.ee/xml/ns/persistence" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">
	<persistence-unit name="reddit-collector">
		<!-- Провайдер Hibernate -->
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>model.CommitVer</class>
		<class>model.EvalRe</class>
		<class>model.EvalRePK</class>
		<class>model.HashToNode</class>
		<class>model.HashToNodePK</class>
		<class>model.HashToRel</class>
		<class>model.HashToRelPK</class>
		<class>model.Node</class>
		<class>model.Rel</class>
		<class>model.RelPK</class>
		<class>model.ScopeInfo</class>
		<class>model.User</class>
        <properties>
            <!-- 1. Настройки подключения -->
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver" />
            <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://localhost:5432/St-Coure-Project-2" />
            <property name="jakarta.persistence.jdbc.user" value="postgres" />
            <property name="jakarta.persistence.jdbc.password" value="test123" />

            <!-- 2. Настройки Hibernate -->
            <!-- Dialect помогает Hibernate писать правильный SQL для Postgres -->
            <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQLDialect" />
            
            <!-- Показывать SQL в консоли (полезно для отладки) -->
            <property name="hibernate.show_sql" value="true" />
            <property name="hibernate.format_sql" value="true" />
            
            <!-- Автоматическое сканирование сущностей (вы просили это ранее) -->
            <property name="hibernate.archive.autodetection" value="class" />
        </properties>
	</persistence-unit>
</persistence>
