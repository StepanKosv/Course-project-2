<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10.0" xmlns="http://javafx.com" xmlns:fx="http://javafx.com" fx:controller="com.stepankosvin.list_view_and_filters_plugin.EdgeListController">
    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
    </padding>
    <children>
        <Button fx:id="refreshButton" mnemonicParsing="false" onAction="#handleRefresh" text="Refresh" />
        <TableView fx:id="edgeTableView" VBox.vgrow="ALWAYS">
          <columns>
            <TableColumn fx:id="idColumn" prefWidth="100.0" text="ID" />
            <TableColumn fx:id="labelColumnL" prefWidth="200.0" text="left Label" />
            <TableColumn fx:id="labelColumn" prefWidth="200.0" text="Label" />
            <TableColumn fx:id="labelColumnR" prefWidth="200.0" text="right Label" />
            <TableColumn fx:id="betweennessCentralityColumn" prefWidth="100.0" text="betweenness" />
            <TableColumn fx:id="idColumnL" prefWidth="100.0" text="left ID" />
            <TableColumn fx:id="closenessCentralityColumnL" prefWidth="100.0" text="left closeness" />
            <TableColumn fx:id="betweennessCentralityColumnL" prefWidth="100.0" text="left betweenness" />
            <TableColumn fx:id="degreeColumnL" prefWidth="100.0" text="left degree" />
            <TableColumn fx:id="idColumnR" prefWidth="100.0" text="right ID" />
            <TableColumn fx:id="closenessCentralityColumnR" prefWidth="100.0" text="right closeness" />
            <TableColumn fx:id="betweennessCentralityColumnR" prefWidth="100.0" text="right betweenness" />
            <TableColumn fx:id="degreeColumnR" prefWidth="100.0" text="right degree" />
          </columns>
        </TableView>
    </children>
</VBox>
