<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10.0" xmlns="http://javafx.com" xmlns:fx="http://javafx.com" fx:controller="com.stepankosvin.list_view_and_filters_plugin.VertexListController">
    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
    </padding>
    <children>
        <Button fx:id="refreshButton" mnemonicParsing="false" onAction="#handleRefresh" text="Refresh" />
        <TableView fx:id="vertexTableView" VBox.vgrow="ALWAYS">
          <columns>
            <TableColumn fx:id="idColumn" prefWidth="100.0" text="ID" />
            <TableColumn fx:id="labelColumn" prefWidth="200.0" text="Label" />
            <TableColumn fx:id="closenessCentralityColumn" prefWidth="100.0" text="closeness" />
            <TableColumn fx:id="betweennessCentralityColumn" prefWidth="100.0" text="betweenness" />
            <TableColumn fx:id="degreeColumn" prefWidth="100.0" text="degree" />
          </columns>
        </TableView>
    </children>
</VBox>
