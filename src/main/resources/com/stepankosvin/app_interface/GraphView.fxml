<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.embed.swing.SwingNode?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" 
            prefHeight="600.0" prefWidth="800.0" 
            xmlns="javafx.com" xmlns:fx="javafx.com" 
            fx:controller="com.stepankosvin.app_interface.GraphViewController">
   <top>
      <HBox spacing="10.0" style="-fx-background-color: #f4f4f4; -fx-border-color: #cccccc; -fx-border-width: 0 0 1 0;" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="refreshButton" mnemonicParsing="false" onAction="#refresh" text="Refresh" />
            <Button fx:id="closeButton" mnemonicParsing="false" onAction="#close" text="Close" />
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </HBox>
   </top>
   <center>
      <StackPane fx:id="graphContainer" BorderPane.alignment="CENTER">
         <children>
            <SwingNode fx:id="swingNode" />
         </children>
      </StackPane>
   </center>
</BorderPane>
