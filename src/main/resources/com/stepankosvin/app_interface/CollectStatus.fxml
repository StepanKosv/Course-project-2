<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<VBox xmlns="javafx.com" xmlns:fx="javafx.com" 
      fx:controller="com.stepankosvin.app_interface.CollectStatusController" 
      spacing="10.0" prefWidth="500.0" prefHeight="400.0">
    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>
    <Label text="статус сбора:"/>
    <Label fx:id="collectState" style="-fx-font-weight: bold;"/>
    <Label text="Лог сообщений сбора:"/>
    <ListView fx:id="messagesList" VBox.vgrow="ALWAYS"/>

    <HBox spacing="10.0" alignment="CENTER_RIGHT">
        <Button fx:id="stopButton" text="Stop" onAction="#handleStop"/>
        <Button fx:id="pauseButton" text="Pause" onAction="#handlePause"/>
        <Button fx:id="continueButton" text="Continue" onAction="#handleContinue"/>
        <Button fx:id="closeButton" text="Close" onAction="#handleClose"/>
    </HBox>
</VBox>
